{
  "items": [
    {
      "kind": "Deployment",
      "metadata": {
        "name": "good-app",
        "namespace": "goose-test"
      },
      "spec": {
        "replicas": 3,
        "selector": {"matchLabels": {"app": "good-app"}},
        "template": {
          "spec": {
            "containers": [
              {
                "name": "good-app",
                "image": "nginx:1.25.3",
                "imagePullPolicy": "IfNotPresent"
              }
            ]
          }
        }
      }
    },
    {
      "kind": "Deployment",
      "metadata": {
        "name": "bad-app",
        "namespace": "goose-test"
      },
      "spec": {
        "replicas": 2,
        "selector": {"matchLabels": {"app": "bad-app"}},
        "template": {
          "spec": {
            "containers": [
              {
                "name": "bad-app",
                "image": "nginx:latest",
                "imagePullPolicy": "Always"
              }
            ]
          }
        }
      }
    },
    {
      "kind": "Deployment",
      "metadata": {
        "name": "ugly-app",
        "namespace": "goose-test"
      },
      "spec": {
        "replicas": 2,
        "selector": {"matchLabels": {"app": "ugly-app"}},
        "template": {
          "spec": {
            "containers": [
              {
                "name": "ugly-app",
                "image": "busybox",
                "imagePullPolicy": "IfNotPresent"
              }
            ]
          }
        }
      }
    },
    {
      "kind": "Deployment",
      "metadata": {
        "name": "single-app",
        "namespace": "goose-test"
      },
      "spec": {
        "replicas": 1,
        "selector": {"matchLabels": {"app": "single-app"}},
        "template": {
          "spec": {
            "containers": [
              {
                "name": "single-app",
                "image": "nginx:1.25.3",
                "imagePullPolicy": "IfNotPresent"
              }
            ]
          }
        }
      }
    }
  ]
}
